# ─── HypoRadar — variables d'environnement ───────────────────────────
# Copier ce fichier en `.env` et remplir les valeurs.
#   cp .env.example .env

# PostgreSQL — base de données principale (Prisma).
# Local : créer la base `hyporadar` puis adapter user/mot de passe.
#   ex. brew install postgresql@17 && createdb hyporadar
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hyporadar?schema=public"

# Auth.js — secret de signature des sessions (JWT).
# Générer avec : openssl rand -base64 32
AUTH_SECRET=""

# URL publique de l'application (liens dans les emails, canonical, sitemap).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth (connexion via Google) — laisser vide pour désactiver le bouton
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Panel de test /campagne (leads Google Ads) — identifiant unique
CAMPAGNE_USER="admin"
CAMPAGNE_PASSWORD="change-me"
