# ─── HypoPilot — variables d'environnement ───────────────────────────
# Copier ce fichier en `.env` et remplir les valeurs.
#   cp .env.example .env

# PostgreSQL — base de données principale (Prisma).
# Local : créer la base `hypopilot` puis adapter user/mot de passe.
#   ex. brew install postgresql@17 && createdb hypopilot
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hypopilot?schema=public"

# Auth.js — secret de signature des sessions (JWT).
# Générer avec : openssl rand -base64 32
AUTH_SECRET=""

# URL publique de l'application (liens dans les emails, canonical, sitemap).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
