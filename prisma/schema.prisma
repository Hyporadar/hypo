generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // runtime : connexion poolée (pgbouncer)
  directUrl = env("DATABASE_URL_UNPOOLED") // migrations : connexion directe
}

// ─── Enums ────────────────────────────────────────────────────────────

enum Role {
  CLIENT
  CLOSER
  PARTNER
  ADMIN
}

enum Locale {
  fr
  de
  it
}

enum Funnel {
  ACHAT
  RENOUVELLEMENT_CHAUD
  RENOUVELLEMENT_FROID
}

enum LeadStatus {
  NOUVEAU
  CONTACTE
  RDV
  DOSSIER_EN_COURS
  DOSSIER_COMPLET
  ENVOYE_PARTENAIRE // règle d'or : uniquement dossier complété ET consenti
  OFFRES_RECUES
  SIGNE
  PERDU
  NURTURING // surveillance — réveillé 12–18 mois avant l'échéance
}

enum MortgageType {
  FIXE
  SARON
}

enum SignalType {
  ABANDON_DOSSIER
  OFFRES_NON_LUES
  OFFRE_EXPIRE_BIENTOT
  ENTREE_FENETRE
  GROSSE_ECONOMIE
  CALLBACK_DEMANDE
}

enum SignalStatus {
  OUVERT
  TRAITE
}

enum OfferStatus {
  ACTIVE
  ACCEPTEE
  REFUSEE
  EXPIREE
}

enum DocumentVerificationStatus {
  EN_ATTENTE
  VALIDE
  REFUSE
}

enum CommissionStatus {
  DUE
  PAYEE
}

enum AppointmentType {
  APPEL
  VISIO
}

enum ClientEventType {
  CONNEXION
  OFFRE_OUVERTE
  SIMULATION_REVUE
  DOSSIER_MIS_A_JOUR
  CERTIFICAT_TELECHARGE
}

enum CommissionKind {
  APPORT_PARTENAIRE
  VARIABLE_CLOSER
  PARRAINAGE
}

// ─── Utilisateurs ─────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  role         Role     @default(CLIENT)
  locale       Locale   @default(fr) // langue des emails, PDF et statuts affichés
  partnerCode  String?  @unique // rôle PARTNER : code d'apport (?ref=CODE sur les landings)
  referralCode String?  @unique // rôle CLIENT : lien de parrainage (?ref=CODE, CHF 100/filleul validé)
  partnerApprovedAt DateTime? // PARTNER : validation manuelle par l'admin
  alertPrefs   Json? // préférences d'alerte client (email/SMS — placeholders)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  leads             Lead[]            @relation("ClientLeads")
  referredLeads     Lead[]            @relation("PartnerLeads")
  sponsoredLeads    Lead[]            @relation("SponsoredLeads")
  assignedLeads     Lead[]            @relation("CloserLeads")
  claimedSignals    Signal[]          @relation("ClaimedSignals")
  clientEvents      ClientEvent[]
  mortgages         Mortgage[]
  purchaseProjects  PurchaseProject[]
  appointments      Appointment[]     @relation("CloserAppointments")
  commissionEntries CommissionEntry[]
  statusChanges     LeadStatusChange[]
}

// ─── Leads (entité centrale) ──────────────────────────────────────────

model Lead {
  id     String     @id @default(cuid())
  funnel Funnel
  status LeadStatus @default(NOUVEAU)
  score  Int        @default(0)
  locale Locale     @default(fr)

  // Contact direct — le lead existe avant tout compte utilisateur
  name  String?
  email String?
  phone String?

  // Source UTM complète + referrer
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  referrer    String?

  // Rattachements (tous nullables : un lead peut précéder le compte client)
  userId    String?
  user      User?   @relation("ClientLeads", fields: [userId], references: [id])
  partnerId String? // apporteur B2B (User PARTNER)
  partner   User?   @relation("PartnerLeads", fields: [partnerId], references: [id])
  sponsorId String? // parrain (User CLIENT — programme de parrainage)
  sponsor   User?   @relation("SponsoredLeads", fields: [sponsorId], references: [id])
  closerId  String? // closer affecté (User CLOSER)
  closer    User?   @relation("CloserLeads", fields: [closerId], references: [id])

  notes String? // notes internes closers

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Horodatage de chaque changement de statut (mesure du speed-to-lead)
  statusHistory     LeadStatusChange[]
  signals           Signal[]
  offers            Offer[]
  documents         Document[]
  commissionEntries CommissionEntry[]
  appointments      Appointment[]
  mortgage          Mortgage?
  purchaseProject   PurchaseProject?
  certificate       Certificate?
  formDrafts        FormDraft[]
  events            ClientEvent[]
  dossier           Dossier?

  @@index([status, funnel])
  @@index([closerId, status])
  @@index([partnerId])
}

// Chaque transition de statut est journalisée avec son horodatage.
// speed-to-lead = premier passage NOUVEAU → CONTACTE.
model LeadStatusChange {
  id          String      @id @default(cuid())
  leadId      String
  lead        Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStatus  LeadStatus? // null à la création du lead
  toStatus    LeadStatus
  changedById String? // null = transition automatique (système)
  changedBy   User?       @relation(fields: [changedById], references: [id])
  changedAt   DateTime    @default(now())

  @@index([leadId, changedAt])
}

// ─── Hypothèque & projet d'achat ──────────────────────────────────────

model Mortgage {
  id              String       @id @default(cuid())
  // Rattaché au compte client OU au lead (funnel public, avant création de compte)
  userId          String?
  user            User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId          String?      @unique
  lead            Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  remainingAmount Decimal      @db.Decimal(12, 2) // montant restant dû, CHF
  currentRate     Decimal      @db.Decimal(6, 3) // taux actuel, en % (ex. 1.250)
  currentLender   String // prêteur actuel
  endDate         DateTime // échéance — pilote tout le routage
  type            MortgageType
  propertyValue   Decimal      @db.Decimal(12, 2) // valeur estimée du bien, CHF
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([endDate])
}

model PurchaseProject {
  id                String   @id @default(cuid())
  // Rattaché au compte client OU au lead (funnel public, avant création de compte)
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId            String?  @unique
  lead              Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  price             Decimal  @db.Decimal(12, 2) // prix du bien, CHF
  ownFunds          Decimal  @db.Decimal(12, 2) // fonds propres totaux, CHF
  ownFundsPillar2   Decimal  @db.Decimal(12, 2) // dont 2e pilier, CHF
  annualGrossIncome Decimal  @db.Decimal(12, 2) // revenu brut annuel du ménage, CHF
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─── File de travail des closers ──────────────────────────────────────

model Signal {
  id          String       @id @default(cuid())
  leadId      String
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        SignalType
  status      SignalStatus @default(OUVERT)
  priority    Int          @default(0) // montant × urgence du type ; CALLBACK toujours en tête
  context     Json? // ex. { reinforced: true, savings: 3200 }
  claimedById String? // closer qui a pris le signal (claim) — sinon pool
  claimedBy   User?        @relation("ClaimedSignals", fields: [claimedById], references: [id])
  createdAt   DateTime     @default(now())
  treatedAt   DateTime?

  @@index([status, priority])
  @@index([leadId, type, status])
}

// ─── Offres & documents ───────────────────────────────────────────────

model Offer {
  id         String      @id @default(cuid())
  leadId     String
  lead       Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  lender     String // prêteur
  rate       Decimal     @db.Decimal(6, 3) // taux proposé, en %
  termYears  Int // durée en années
  validUntil DateTime // validité de l'offre
  status     OfferStatus @default(ACTIVE)
  createdAt  DateTime    @default(now())

  @@index([leadId, status])
}

model Document {
  id                 String                     @id @default(cuid())
  leadId             String
  lead               Lead                       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type               String // ex. "piece-identite", "certificat-salaire", "extrait-rf"
  url                String
  verificationStatus DocumentVerificationStatus @default(EN_ATTENTE)
  createdAt          DateTime                   @default(now())

  @@index([leadId])
}

// ─── Certificats de capacité d'achat ──────────────────────────────────

// Le PDF circule chez les agents immobiliers : numéro unique + QR de
// vérification vers /verify/[id]. Les données sont figées à l'émission
// (le certificat reste conforme même si les règles évoluent).
model Certificate {
  id        String   @id @default(cuid()) // utilisé dans l'URL de vérification
  number    String   @unique // ex. HP-2026-000042
  leadId    String   @unique
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  locale    Locale // langue du PDF
  holder    String // nom du porteur, tel qu'imprimé
  data      Json // snapshot : prix, fonds propres, revenu, résultat, fourchette de taux
  createdAt DateTime @default(now())
}

// ─── Brouillons de formulaire (détection des abandons) ────────────────

// Persisté dès que l'email est connu ; avant, le brouillon vit en localStorage.
model FormDraft {
  id          String    @id // uuid généré côté client (stable entre les étapes)
  funnel      Funnel
  locale      Locale
  step        Int       @default(0)
  email       String?
  data        Json
  leadId      String?
  lead        Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  completedAt DateTime? // null = abandon potentiel
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([funnel, completedAt, updatedAt])
}

// ─── Taux de référence nationaux (gérés par l'admin) ──────────────────

model ReferenceRate {
  id        String       @id @default(cuid())
  type      MortgageType @default(FIXE)
  termYears Int // durée en années (0 = SARON)
  rate      Decimal      @db.Decimal(6, 3) // taux, en %
  updatedAt DateTime     @updatedAt

  @@unique([type, termYears])
}

// ─── Commissions ──────────────────────────────────────────────────────

// bénéficiaire = partner, closer ou parrain (kind qualifie la commission)
model CommissionEntry {
  id            String           @id @default(cuid())
  beneficiaryId String
  beneficiary   User             @relation(fields: [beneficiaryId], references: [id])
  leadId        String
  lead          Lead             @relation(fields: [leadId], references: [id])
  kind          CommissionKind   @default(APPORT_PARTENAIRE)
  amount        Decimal          @db.Decimal(12, 2) // CHF
  status        CommissionStatus @default(DUE)
  paidAt        DateTime?
  createdAt     DateTime         @default(now())

  @@index([beneficiaryId, status])
}

// ─── Événements clients (module src/server/events.ts) ─────────────────

// Chaque action importante du client — consommé par le moteur de signaux.
model ClientEvent {
  id        String          @id @default(cuid())
  type      ClientEventType
  userId    String?
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  leadId    String?
  lead      Lead?           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  data      Json?
  createdAt DateTime        @default(now())

  @@index([leadId, type, createdAt])
  @@index([userId, createdAt])
}

// ─── Historique des taux (page /taux + graphique) ──────────────────────

model ReferenceRateChange {
  id         String       @id @default(cuid())
  type       MortgageType
  termYears  Int
  rate       Decimal      @db.Decimal(6, 3)
  recordedAt DateTime     @default(now())

  @@index([type, termYears, recordedAt])
}

// Historique quotidien des taux dérivés des données publiques BNS
// (append-only, un enregistrement par jour de données BNS). `yields` =
// rendements Confédération bruts, `computed` = taux affichés (ancre + delta).
model RateSnapshot {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date // date des données BNS
  saron     Decimal? @db.Decimal(6, 3)
  yields    Json // { "2": .., "5": .., "10": .., "15": .. }
  computed  Json // { "saron": .., "2": .., ..., "15": .. }
  createdAt DateTime @default(now())

  @@index([date])
}

// ─── Dépenses marketing (CAC par canal, saisie manuelle admin) ─────────

model ChannelSpend {
  id      String   @id @default(cuid())
  channel String // correspond à utmSource (ex. google, facebook)
  month   DateTime // 1er jour du mois
  amount  Decimal  @db.Decimal(12, 2) // CHF

  @@unique([channel, month])
}

// ─── Abonnements aux mises à jour de taux (widget home) ───────────────

enum RateAlertFrequency {
  QUOTIDIEN
  HEBDOMADAIRE
  MENSUEL
}

model RateSubscription {
  id               String             @id @default(cuid())
  email            String             @unique
  locale           Locale             @default(fr)
  frequency        RateAlertFrequency @default(HEBDOMADAIRE)
  dossierId        String? // souscrit depuis le wizard
  confirmToken     String?            @unique // double opt-in
  confirmedAt      DateTime?
  unsubscribeToken String             @unique @default(cuid()) // désinscription 1 clic
  lastSentAt       DateTime?
  unsubscribedAt   DateTime?
  createdAt        DateTime           @default(now())

  @@index([frequency, lastSentAt])
}

// ─── Journal d'emails (provider mocké + idempotence du nurturing) ──────

model EmailLog {
  id       String   @id @default(cuid())
  to       String
  locale   Locale
  template String // ex. "abandon-j1", "offres-non-lues", "trimestriel"
  subject  String
  leadId   String?
  sentAt   DateTime @default(now())

  @@index([leadId, template])
}

// ─── Agenda ───────────────────────────────────────────────────────────

model Appointment {
  id        String          @id @default(cuid())
  closerId  String
  closer    User            @relation("CloserAppointments", fields: [closerId], references: [id])
  leadId    String
  lead      Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  date      DateTime
  type      AppointmentType
  notes     String?
  createdAt DateTime        @default(now())

  @@index([closerId, date])
}

// ═══════════════════════════════════════════════════════════════════════
// MODULE DOSSIER — wizard structuré + versionnage immuable (LSFin/LBA)
// DossierVersion.data (JSON) = vérité immuable, jamais purgée.
// Les tables structurées = état COURANT dénormalisé (requêtes admin).
// ═══════════════════════════════════════════════════════════════════════

enum VersionAuthor {
  LEAD
  CLOSER
  ADMIN
  SYSTEM
}

enum UsageBien {
  RESIDENCE_PRINCIPALE
  RESIDENCE_SECONDAIRE
  RENDEMENT
}

enum TypeBien {
  MAISON
  APPARTEMENT_PPE
  MAISON_MITOYENNE
  IMMEUBLE
}

enum PositionMaison {
  INDIVIDUELLE
  JUMELEE
  MITOYENNE_CENTRALE
  MITOYENNE_ANGLE
}

enum ProduitTranche {
  FIXE
  SARON
  VARIABLE
}

enum StatutActivite {
  SALARIE
  INDEPENDANT
  RETRAITE
  SANS_ACTIVITE
}

enum TypeRevenu {
  SALAIRE
  BONUS
  INDEPENDANT
  RENTE
  REVENU_LOCATIF
  AUTRE
}

enum TypeCharge {
  LEASING
  CREDIT
  PENSION_ALIMENTAIRE
  AUTRE
}

enum TypeAvoir {
  COMPTE_EPARGNE
  TITRES
  PILIER_3A
  LIBRE_PASSAGE
  CAPITAL_LPP
  DONATION
  AUTRE
}

enum TypeLender {
  BANQUE
  ASSURANCE
  CAISSE_PENSION
}

enum DossierEventType {
  WIZARD_STEP_COMPLETED
  WIZARD_ABANDONED
  COMPLEX_CASE_DETECTED
  RATE_ALERT_SUBSCRIBED
  OFFERS_VIEWED
  ACCOUNT_CREATED
  VERSION_CREATED
  CONSULTATION
}

model Dossier {
  id             String   @id // uuid généré côté client (dossier anonyme)
  funnel         Funnel
  locale         Locale   @default(fr)
  leadId         String?  @unique // rattaché au Lead pipeline au 1er save
  lead           Lead?    @relation(fields: [leadId], references: [id])
  userId         String? // rattaché au compte après magic link
  complex        Boolean  @default(false)
  complexReasons String[] @default([])

  currentVersionId String? @unique
  completude       Int      @default(0) // % dénormalisé (liste admin)
  echeanceProche   DateTime? // min(échéances tranches existantes) — tri admin
  lastActivityAt   DateTime  @default(now()) // détection d'abandon
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  versions           DossierVersion[]
  bien               Bien?
  emprunteurs        Emprunteur[]
  tranchesExistantes TrancheExistante[]
  tranchesSouhaitees TrancheSouhaitee[]
  autresBiens        AutreBien[]
  dossierEvents      DossierEvent[]

  @@index([echeanceProche])
  @@index([completude])
}

// Version immuable : AUCUNE update/delete n'est exposée (traçabilité LSFin/LBA).
model DossierVersion {
  id              String        @id @default(cuid())
  dossierId       String
  dossier         Dossier       @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  numero          Int // v1, v2…
  data            Json // snapshot complet (format DossierData zod)
  authorType      VersionAuthor
  authorId        String?
  authorName      String
  commentaire     String? // obligatoire si authorType=CLOSER (validé serveur)
  parentVersionId String?
  createdAt       DateTime      @default(now())

  @@unique([dossierId, numero])
  @@index([dossierId, createdAt])
}

model Bien {
  id        String  @id @default(cuid())
  dossierId String  @unique
  dossier   Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  usage    UsageBien?
  type     TypeBien?
  position PositionMaison?

  rue         String?
  npa         String?
  localite    String?
  canton      String?
  lat         Decimal? @db.Decimal(9, 6)
  lng         Decimal? @db.Decimal(9, 6)
  geoConfirme Boolean  @default(false)

  anneeConstruction Int?
  anneeRenovation   Int?
  pieces            Decimal? @db.Decimal(4, 1)
  sallesEau         Json? // { baignoires, douches, wc }
  surfaceHabitable  Int?
  chauffage         String?
  labelEco          String?

  etatCuisine     Int? // 1..7
  etatSallesBains Int?
  etatInterieur   Int?
  etatExterieur   Int?

  servitudes           Boolean?
  zoneAgricole         Boolean?
  nouvelleConstruction Boolean?

  valeur       Decimal? @db.Decimal(12, 2)
  prixAchat    Decimal? @db.Decimal(12, 2)
  fondsPropres Decimal? @db.Decimal(12, 2)
}

model TrancheExistante {
  id        String         @id @default(cuid())
  dossierId String
  dossier   Dossier        @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  ordre     Int
  lenderId  String?
  lender    Lender?        @relation(fields: [lenderId], references: [id])
  lenderNom String?
  montant   Decimal        @db.Decimal(12, 2)
  taux      Decimal?       @db.Decimal(6, 3)
  produit   ProduitTranche @default(FIXE)
  echeance  DateTime?

  @@index([dossierId, ordre])
}

model TrancheSouhaitee {
  id          String         @id @default(cuid())
  dossierId   String
  dossier     Dossier        @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  ordre       Int
  produit     ProduitTranche @default(FIXE)
  dureeAnnees Int?
  montant     Decimal        @db.Decimal(12, 2)

  @@index([dossierId, ordre])
}

model Emprunteur {
  id        String  @id @default(cuid())
  dossierId String
  dossier   Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  ordre     Int // 1..4

  prenom                      String?
  nom                         String?
  anneeNaissance              Int?
  etatCivil                   String?
  nationalite                 String?
  permis                      String?
  statutActivite              StatutActivite?
  dureeActiviteRestanteMois   Int?
  employeur                   String?

  revenus    Revenu[]
  charges    Charge[]
  avoirs     Avoir[]
  poursuites Poursuite[]

  @@unique([dossierId, ordre])
}

model Revenu {
  id            String     @id @default(cuid())
  emprunteurId  String
  emprunteur    Emprunteur @relation(fields: [emprunteurId], references: [id], onDelete: Cascade)
  type          TypeRevenu
  montantAnnuel Decimal    @db.Decimal(12, 2)
  libelle       String?
}

model Charge {
  id              String     @id @default(cuid())
  emprunteurId    String
  emprunteur      Emprunteur @relation(fields: [emprunteurId], references: [id], onDelete: Cascade)
  type            TypeCharge
  montantAnnuel   Decimal    @db.Decimal(12, 2)
  echeanceLeasing DateTime?
}

model Avoir {
  id              String     @id @default(cuid())
  emprunteurId    String
  emprunteur      Emprunteur @relation(fields: [emprunteurId], references: [id], onDelete: Cascade)
  type            TypeAvoir
  montant         Decimal    @db.Decimal(12, 2)
  utilisePourAchat Boolean   @default(false)
}

model Poursuite {
  id           String     @id @default(cuid())
  emprunteurId String
  emprunteur   Emprunteur @relation(fields: [emprunteurId], references: [id], onDelete: Cascade)
  soldee       Boolean
  montant      Decimal?   @db.Decimal(12, 2)
  motif        String?
}

model AutreBien {
  id                  String   @id @default(cuid())
  dossierId           String
  dossier             Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  type                String?
  valeur              Decimal? @db.Decimal(12, 2)
  hypothequeRestante  Decimal? @db.Decimal(12, 2)
  revenuLocatifAnnuel Decimal? @db.Decimal(12, 2)
}

// Prêteurs suisses (~40 seedés) — autocomplete insensible aux accents/abréviations.
model Lender {
  id       String     @id @default(cuid())
  nom      String     @unique
  nomCourt String
  alias    String[]   @default([])
  type     TypeLender
  actif    Boolean    @default(true)

  tranchesExistantes TrancheExistante[]
}

// Base NPA suisse (GeoNames, CC-BY) — autocomplete « VD-1003 Lausanne ».
model SwissLocality {
  id        String @id @default(cuid())
  npa       String
  localite  String
  canton    String
  recherche String @default("") // « npa localite canton » normalisé (sans accents) pour l'autocomplete

  @@unique([npa, localite])
  @@index([npa])
  @@index([localite])
  @@index([recherche])
}

// Événements du wizard + audit log léger (CONSULTATION par rôle).
model DossierEvent {
  id        String           @id @default(cuid())
  dossierId String
  dossier   Dossier          @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  type      DossierEventType
  data      Json?
  actorType VersionAuthor?
  actorId   String?
  createdAt DateTime         @default(now())

  @@index([dossierId, createdAt])
}

// Magic link « Sauvegarder mon dossier » / « Recevoir mes offres fermes ».
model MagicLinkToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  dossierId String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// ─── Site de TEST (campagne Google Ads) ────────────────────────────────
// Landing /lp + wizard en mode test : les soumissions atterrissent ICI,
// pas dans les tables Dossier/Lead du vrai produit. Un admin ultra-simple
// (/campagne) les liste pour mesurer le coût par lead.
model TestLead {
  id           String   @id @default(cuid())
  dossierId    String   @unique // uuid client (dédup des soumissions)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  funnel       String
  completude   Int      @default(0)
  data         Json // snapshot complet du formulaire (DossierData)
  name         String?
  email        String?
  phone        String?
  callbackDate String?
  callbackSlot String?
  echeance     String? // tranche d'échéance (parcours court renouvellement)
  message      String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  referrer     String?

  @@index([createdAt])
}

// Journal d'événements anonymes de l'entonnoir de conversion. Une ligne par
// (visiteur, étape) : la contrainte d'unicité garantit qu'un visiteur n'est
// compté qu'une fois par étape. Aucune donnée personnelle (id de session
// aléatoire côté navigateur).
model FunnelEvent {
  id        String   @id @default(cuid())
  sessionId String
  step      String // visit | criteria | advance | contact
  createdAt DateTime @default(now())

  @@unique([sessionId, step])
  @@index([step, createdAt])
}
